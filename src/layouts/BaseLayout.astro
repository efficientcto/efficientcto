---
const { title = 'Efficient CTO', description = 'Fractional CTO and technology leadership for startups and growing businesses.' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href="https://efficientcto.com" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://efficientcto.com" />
    <meta property="og:site_name" content="Efficient CTO" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="stylesheet" href="/global.css" />
  </head>
  <body>
    <slot />
  </body>
</html>
