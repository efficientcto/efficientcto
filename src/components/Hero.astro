---
const strategyCallUrl = "https://your-booking-link-here";
---

<section style="padding: 6rem 0; text-align: center;">
  <h1 style="font-size: 3rem; font-weight: 700; color: var(--color-navy); max-width: 800px; margin: 0 auto;">
    Technology Leadership Without the Full-Time CTO Salary
  </h1>

  <p style="font-size: 1.25rem; color: #475569; max-width: 700px; margin: 1.5rem auto 2.5rem;">
    Fractional CTO services that help startups and growing businesses build scalable software,
    improve engineering execution, and make better technical decisions.
  </p>

  <div style="display: flex; justify-content: center; gap: 1rem;">
    <a href={strategyCallUrl} class="btn btn-primary">Book a Strategy Call</a>
    <a href="/services" class="btn btn-outline">Explore Services</a>
  </div>
</section>
