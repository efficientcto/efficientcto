---
const { number, title, text } = Astro.props;
---

<div style="text-align: center; max-width: 260px;">
  <div style="
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  ">
    {number}
  </div>
  <h4 style="margin: 0; color: var(--color-navy);">{title}</h4>
  <p style="color: #475569; font-size: 0.9rem; margin-top: 0.5rem;">{text}</p>
</div>
